{
  "name": "apurba-labs/laravel-iam",
  "description": "Laravel IAM (Identity & Access Management) package with hierarchical permissions, wildcard support, and SaaS-ready design.",
  "type": "library",
  "license": "MIT",

  "keywords": [
    "laravel",
    "rbac",
    "iam",
    "permissions",
    "authorization",
    "saas",
    "access-control"
  ],

  "autoload": {
    "psr-4": {
      "ApurbaLabs\\IAM\\": "src/",
      "ApurbaLabs\\IAM\\Database\\Seeders\\": "database/seeders/",
      "ApurbaLabs\\IAM\\Database\\Factories\\": "database/factories/"
    }
  },

  "autoload-dev": {
    "psr-4": {
      "ApurbaLabs\\IAM\\Tests\\": "tests/",
      "ApurbaLabs\\IAM\\Tests\\Support\\": "tests/Support/"
    }
  },

  "extra": {
    "laravel": {
      "providers": [
        "ApurbaLabs\\IAM\\Providers\\IAMServiceProvider"
      ],
      "aliases": {
          "IAM": "ApurbaLabs\\IAM\\Facades\\IAM"
      }
    }
  },

  "require": {
    "php": "^8.1",
    "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
  },

  "require-dev": {
    "orchestra/testbench": "^8.0|^9.0",
    "phpunit/phpunit": "^10.0",
    "doctrine/dbal": "^4.0"
  },

  "minimum-stability": "dev",
  "prefer-stable": true
}