{
  "name": "apurba-labs/laravel-iam",
  "description": "Identity and Access Management package for Laravel",
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "ApurbaLabs\\IAM\\": "src/",
      "ApurbaLabs\\IAM\\Database\\Seeders\\": "database/seeders/",
      "ApurbaLabs\\IAM\\Database\\Factories\\": "database/factories/"
    }
  },
  "autoload-dev": {
    "psr-4": {
        "ApurbaLabs\\IAM\\Tests\\": "tests/",
        "ApurbaLabs\\IAM\\Tests\\Support\\": "tests/Support/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "ApurbaLabs\\IAM\\IAMServiceProvider"
      ]
    }
  },
  "require": {
    "php": "^8.1",
    "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
  },
  "require-dev": {
     "orchestra/testbench": "*",
     "phpunit/phpunit": "^10.0",
    "doctrine/dbal": "^4.4"
  }
}
